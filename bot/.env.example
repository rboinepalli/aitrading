# =============================================================================
# .env.example — copy to .env and fill in your values for local development.
# Railway reads these from its "Variables" dashboard (never commit .env!).
# =============================================================================

# --- Alpaca (paper trading) ---
# Sign up at https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Supabase ---
# Project Settings → API → Project URL + service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here    # never expose this in the browser

# --- Signal tuning (safe to leave as defaults) ---
RSI_PERIOD=14
RSI_OVERSOLD=30        # buy signal when RSI drops below this
RSI_OVERBOUGHT=70      # (reserved for bear-side logic)
EMA_FAST=9             # fast EMA period
EMA_SLOW=21            # slow EMA period

# --- Regime thresholds ---
VIX_BEAR_THRESHOLD=25  # VIX above this → BEAR regime
VIX_BULL_THRESHOLD=18  # VIX below this AND price > 200-DMA → BULL regime

# --- Risk limits ---
MAX_POSITION_USD=2000  # max dollars per trade
MAX_DAILY_LOSS_USD=500 # stop trading for the day if losses hit this
TAKE_PROFIT_PCT=0.15   # close at +15%
STOP_LOSS_PCT=0.10     # close at -10%
EOD_CLOSE_TIME=15:45   # hard close time (ET), format HH:MM
