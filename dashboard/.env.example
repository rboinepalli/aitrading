# Copy to .env.local for local development.
# Set these in Vercel's project settings for production.
#
# Use the ANON key here — it's safe for the browser.
# The anon key can only read data because of the Row Level Security policies
# we set up in the Supabase migration (the bot uses the SERVICE key for writes).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
